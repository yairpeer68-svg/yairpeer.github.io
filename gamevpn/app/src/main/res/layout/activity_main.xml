<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070C18"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ping\nBooster"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="0.9"/>

            <!-- Status dot -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/pill_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_inactive"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/statusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="כבוי"
                    android:textColor="#6B8AAA"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- MAIN TOGGLE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Ring + Button -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center">

                <!-- Outer ring -->
                <View
                    android:id="@+id/outerRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/ring_inactive"/>

                <!-- Power button -->
                <Button
                    android:id="@+id/btnToggle"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:text="⏻"
                    android:textSize="52sp"
                    android:textColor="#3D5570"
                    android:background="@drawable/power_btn_inactive"
                    android:elevation="4dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/modeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="לחץ להפעלה"
                android:textColor="#3D5570"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/modeDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מצב משחק מנתב את כל הנתונים\nישירות למשחק שלך"
                android:textColor="#3D5570"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:weightSum="3">

            <!-- Ping -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/statPing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FF9500"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ms"
                    android:textColor="#3D5570"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ping"
                    android:textColor="#3D5570"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Download -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/statDl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#00C8FF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mbps"
                    android:textColor="#3D5570"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורדה"
                    android:textColor="#3D5570"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Upload -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/statUl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#00FFAA"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mbps"
                    android:textColor="#3D5570"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="העלאה"
                    android:textColor="#3D5570"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- GAME SELECTION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮  בחר משחק מועדף"
                android:textColor="#E8F4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"/>

            <!-- Call of Duty -->
            <LinearLayout
                android:id="@+id/gameCod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/game_item_selected"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🎯  Call of Duty Mobile"
                    android:textColor="#E8F4FF"
                    android:textSize="13sp"/>
                <View
                    android:id="@+id/dotCod"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_active"/>
            </LinearLayout>

            <!-- PUBG -->
            <LinearLayout
                android:id="@+id/gamePubg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/game_item_normal"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🪖  PUBG Mobile"
                    android:textColor="#6B8AAA"
                    android:textSize="13sp"/>
                <View
                    android:id="@+id/dotPubg"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_inactive"/>
            </LinearLayout>

            <!-- Free Fire -->
            <LinearLayout
                android:id="@+id/gameFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/game_item_normal"
                android:padding="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🔥  Free Fire"
                    android:textColor="#6B8AAA"
                    android:textSize="13sp"/>
                <View
                    android:id="@+id/dotFF"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_inactive"/>
            </LinearLayout>
        </LinearLayout>

        <!-- INFO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡  איך זה עובד?"
                android:textColor="#E8F4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓  מנתב כל התעבורה דרך VPN מקומי"
                android:textColor="#6B8AAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓  המשחק שבחרת מקבל חיבור ישיר מלא"
                android:textColor="#6B8AAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓  כל שאר האפליקציות נחסמות ברקע"
                android:textColor="#6B8AAA"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
